{
  "name": "notion-embed-js",
  "version": "1.2.0",
  "description": "Embed Notion pages (iframe) or render a native calendar from API-fetched events; optional NOTION_API_KEY / NOTION_CALENDAR_DATABASE_ID server module",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server/notion-calendar.js",
      "require": "./dist/server/notion-calendar.js",
      "types": "./dist/server/notion-calendar.d.ts",
      "default": "./dist/server/notion-calendar.js"
    }
  },
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build:watch": "tsc --watch",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm run build && changeset publish"
  },
  "keywords": [
    "notion",
    "embed",
    "calendar",
    "widget"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@notionhq/client": "^5.17.0"
  },
  "peerDependencies": {
    "@radix-ui/react-popover": "^1.1.14",
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "@radix-ui/react-popover": "^1.1.14",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitest/coverage-v8": "1.6.1",
    "eslint": "^10.2.0",
    "jsdom": "^23.0.0",
    "prettier": "^3.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.58.1",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
