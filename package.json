{
  "name": "notion-embed-js",
  "version": "1.0.0",
  "description": "Embed Notion pages (iframe) or render a native calendar from API-fetched events; optional NOTION_API_KEY / NOTION_CALENDAR_DATABASE_ID server module",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "import": "./dist/server/notion-calendar.js",
      "require": "./dist/server/notion-calendar.js",
      "types": "./dist/server/notion-calendar.d.ts",
      "default": "./dist/server/notion-calendar.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "pnpm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "build:watch": "tsc --watch"
  },
  "keywords": [
    "notion",
    "embed",
    "calendar",
    "widget"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@notionhq/client": "^5.17.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "jsdom": "^23.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
